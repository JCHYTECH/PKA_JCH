#!/usr/bin/env zsh
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: scripts/md2pdf FILE.md [pandoc options...]

Converts a Markdown file to PDF next to the source file.

Examples:
  scripts/md2pdf wiki/SOPs/SOP-007-test-terrain-birdnet-mobile-24h.md
  scripts/md2pdf "JCH_Inbox/00_INBOX/mon fichier.md" --toc --number-sections
EOF
}

if [[ $# -lt 1 || "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

input="$1"
shift

if [[ ! -f "$input" ]]; then
  echo "md2pdf: file not found: $input" >&2
  exit 1
fi

case "$input" in
  *.md|*.markdown) ;;
  *)
    echo "md2pdf: expected a .md or .markdown file: $input" >&2
    exit 1
    ;;
esac

if ! command -v pandoc >/dev/null 2>&1; then
  echo "md2pdf: pandoc not found in PATH" >&2
  exit 1
fi

eval "$(/usr/libexec/path_helper)"

if ! command -v xelatex >/dev/null 2>&1; then
  echo "md2pdf: xelatex not found in PATH. Install MacTeX or restart the terminal after installation." >&2
  exit 1
fi

output="${input%.*}.pdf"

pandoc "$input" \
  -o "$output" \
  --pdf-engine=xelatex \
  "$@"

echo "$output"
